  "item": [
    {
      "id": "cf2848b3-dea9-420b-8466-38a8a2a18330",
      "name": "JSON-RPC",
      "description": {
        "content": "Standard JSON-RPC 2.0 endpoint for sending blockchain RPC requests. Supports Ethereum, Solana, and other chain-specific RPC methods with automatic provider routing, failover, and retry logic.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "9d901c13-bf1d-4b57-8b69-12bad716e3f6",
          "name": "Send a JSON-RPC Request",
          "request": {
            "name": "Send a JSON-RPC Request",
            "description": {
              "content": "Sends a standard JSON-RPC 2.0 request to the specified blockchain network. Uniblock automatically routes the request to the best available upstream node provider based on reliability, cost, and performance. Supports standard Ethereum methods like eth_blockNumber, eth_getBalance, eth_call, eth_sendRawTransaction, eth_getTransactionByHash, eth_getLogs, and others, as well as Solana and chain-specific methods.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "json-rpc",
                "v1",
                ":chain"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "chain",
                  "description": "(Required) The blockchain network to send the JSON-RPC request to (e.g., ethereum, polygon, solana, bsc, arbitrum, optimism, avalanche, base)."
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"<string>\",\n  \"id\": \"<integer>\",\n  \"method\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
