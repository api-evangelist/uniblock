  "info": {
    "_postman_id": "d2df21c8-dc29-4a90-89d3-fe0cb2ae6030",
    "name": "Uniblock JSON-RPC API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Uniblock JSON-RPC API provides a single endpoint for standard JSON-RPC calls across hundreds of blockchain networks. Rather than managing individual node provider connections for each chain, developers can send JSON-RPC requests through Uniblock which automatically selects the best upstream node provider. This supports standard Ethereum and EVM-compatible JSON-RPC methods, Solana RPC interfaces, and other chain-specific RPC methods, with built-in failover and automatic retries across 55+ providers.\n\nContact Support:\n Name: Uniblock Support",
      "type": "text/plain"
    }
  }
